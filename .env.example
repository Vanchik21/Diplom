# Copy this file to .env and fill in all values before running docker compose.

# PostgreSQL
POSTGRES_DB=physis
POSTGRES_USER=physis
POSTGRES_PASSWORD=changeme

# Backend
ConnectionStrings__Default=Host=postgres;Database=physis;Username=physis;Password=changeme
Jwt__Secret=change-this-to-a-long-random-string-at-least-32-chars
Jwt__Issuer=Physis
Jwt__Audience=Physis
Jwt__AccessTokenExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=7
AllowedOrigins__0=http://localhost:4200
