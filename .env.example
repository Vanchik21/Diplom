# Copy this file to .env and fill in all values before running the backend.

# PostgreSQL (native install on localhost)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=physis
POSTGRES_PASSWORD=physis_dev_password_2026
POSTGRES_DB=physis

# Backend
ConnectionStrings__Default=Host=localhost;Port=5432;Database=physis;Username=physis;Password=physis_dev_password_2026
Jwt__Secret=change-this-to-a-long-random-string-at-least-32-chars
Jwt__Issuer=Physis
Jwt__Audience=Physis
Jwt__AccessTokenExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=7
AllowedOrigins__0=http://localhost:4200
