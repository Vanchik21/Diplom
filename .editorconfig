root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript / JavaScript / JSON / SCSS / HTML
[*.{ts,js,json,scss,html,yml,yaml}]
indent_style = space
indent_size = 2

# C# / XML
[*.{cs,csproj,sln,props,targets,xaml}]
indent_style = space
indent_size = 4

# Markdown — preserve trailing spaces (line breaks)
[*.md]
trim_trailing_whitespace = false
