{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npx ng build --configuration production",
  "outputDirectory": "dist/frontend/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://diplom-production-cba6.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://diplom-production-cba6.up.railway.app/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets).*)",
      "destination": "/index.html"
    }
  ]
}
